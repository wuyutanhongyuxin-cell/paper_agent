# compile.ps1 — generated by paper-agent (latexmk wrapper)
$ErrorActionPreference = "Stop"

# UTF-8 stdio for Windows cp936
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
chcp 65001 | Out-Null

$Root = '{{ paper_root }}'
$Src  = "$Root\src"
$Out  = "$Root\out"
$Tex  = "$Src\{{ paper_name }}.tex"
$Latexmkrc = "$Root\.latexmkrc"

if (-not (Test-Path $Out)) {
    New-Item -ItemType Directory -Path $Out | Out-Null
}

Push-Location $Src
try {
    & latexmk -r $Latexmkrc -outdir=$Out $Tex
    if ($LASTEXITCODE -ne 0) { throw "latexmk failed: $LASTEXITCODE" }

    $pdf = Join-Path $Out '{{ paper_name }}.pdf'
    if (Test-Path $pdf) {
        $size = (Get-Item $pdf).Length
        Write-Host "[DONE] $pdf ($size bytes)"
    } else {
        throw "Compilation finished but {{ paper_name }}.pdf not found in $Out"
    }

    # Post-flight chktex (informational only)
    if (Get-Command chktex -ErrorAction SilentlyContinue) {
        & chktex -q -o "$Out\chktex.log" $Tex 2>&1 | Out-Null
        Write-Host "[post] chktex log -> $Out\chktex.log"
    }
} finally {
    Pop-Location
}
