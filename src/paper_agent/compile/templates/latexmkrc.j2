# .latexmkrc — generated by paper-agent (requires latexmk >= 4.70)
# spec §D.5 / §F.8: $xelatex 用 %O 触发 latexmk 自动注入 -no-pdf（manpage v4.88 documented contract）

$pdf_mode = 5;                                                  # xelatex + xdvipdfmx 两步流程
$xelatex = "xelatex -interaction=nonstopmode -synctex=1 %O %S";
$biber = "biber --output-directory=%O %O %S";

# Pre-flight audit-gate（spec §D.5 推荐注入）
$pre_compile_hook = sub {
    my $exit = system('paper-agent', 'audit', '{{ paper_root }}', '--rules', '{{ rules }}', '--strict');
    die "Pre-flight audit failed (exit $exit)" if $exit != 0;
};
